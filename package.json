    "cli",
    "coding-agents",
    "project-template"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
