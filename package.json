{
  "name": "forgeai-agentic-init",
  "version": "3.0.0",
  "description": "AI project initialization kit for agentic coding workflows.",
  "type": "module",
  "bin": {
    "forgeai-init": "dist/forgeai-init.js"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json",
    "test": "npm run typecheck && npm run build && node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm test"
  },
  "files": [
    "dist",
    "profiles",
    "templates",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daithanh-quan/forgeai-agentic.git"
  },
  "bugs": {
    "url": "https://github.com/daithanh-quan/forgeai-agentic/issues"
  },
  "homepage": "https://github.com/daithanh-quan/forgeai-agentic#readme",
  "keywords": [
    "ai",
    "agentic",
    "cli",
    "coding-agents",
    "project-template"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.7"
  }
}
