{
  "name": "forgeai-agentic-init",
  "version": "2.2.0",
  "description": "AI project initialization kit for agentic coding workflows.",
  "type": "module",
  "bin": {
    "forgeai-init": "bin/forgeai-init.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --import tsx --test test/*.test.ts",
