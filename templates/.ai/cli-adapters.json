{
  "version": 1,
  "fallback": {
    "behavior": "current_model_executes_locally",
    "on": [
      "missing_adapter",
      "missing_command",
      "failed_healthcheck",
      "quota_or_rate_limit",
      "command_failed"
    ]
  },
  "adapters": {
    "claude": {
      "command": "claude",
      "args": ["--model", "{model}"],
      "healthcheck": {
        "args": ["--version"],
        "timeout_ms": 5000
      },
      "input": "stdin",
      "quota_patterns": [
        "quota",
        "rate limit",
        "rate_limit",
        "too many requests",
        "insufficient_quota",
        "credit balance",
        "billing"
      ]
    },
    "codex": {
      "command": "codex",
      "args": ["exec", "--model", "{model}"],
      "healthcheck": {
        "args": ["--version"],
        "timeout_ms": 5000
      },
      "input": "stdin",
      "quota_patterns": [
        "quota",
        "rate limit",
        "rate_limit",
        "too many requests",
        "insufficient_quota",
        "credit balance",
        "billing"
      ]
    },
    "gemini": {
      "command": "gemini",
      "args": ["-m", "{model}"],
      "healthcheck": {
        "args": ["--version"],
        "timeout_ms": 5000
      },
      "input": "stdin",
      "quota_patterns": [
        "quota",
        "rate limit",
        "rate_limit",
        "too many requests",
        "resource exhausted",
        "credit balance",
        "billing"
      ]
    },
    "ollama": {
      "command": "ollama",
      "args": ["run", "{model}"],
      "healthcheck": {
        "args": ["--version"],
        "timeout_ms": 5000
      },
      "input": "stdin",
      "quota_patterns": []
    },
    "aider": {
      "command": "aider",
      "args": ["--model", "{model}", "--message", "{assignment}"],
      "healthcheck": {
        "args": ["--version"],
        "timeout_ms": 5000
      },
      "input": "argv",
      "quota_patterns": [
        "quota",
        "rate limit",
        "rate_limit",
        "too many requests",
        "insufficient_quota",
        "credit balance",
        "billing"
      ]
    }
  }
}
